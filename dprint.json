{
  "typescript": {
    "quoteStyle": "preferSingle",
    "semiColons": "asi"
  },
  "json": {
    "indentWidth": 2
  },
  "includes": ["src/**/*.{ts,js}", "tests/**/*.ts", "*.json", "*.ts"],
  "excludes": ["dist/", "node_modules/", "*-lock.*"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.95.15.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm"
  ]
}
